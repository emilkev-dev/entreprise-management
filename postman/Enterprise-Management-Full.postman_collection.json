{
  "info": {
    "name": "Enterprise Management API - Full CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection complète CRUD pour la plateforme de gestion d'entreprise"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:5000" },
    { "key": "token", "value": "" },
    { "key": "employeeId", "value": "1" },
    { "key": "departmentId", "value": "1" },
    { "key": "roleId", "value": "1" },
    { "key": "leaveId", "value": "1" },
    { "key": "attendanceId", "value": "1" },
    { "key": "payrollId", "value": "1" },
    { "key": "contractId", "value": "1" }
  ],
  "item": [
    {
      "name": "0 - Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          }
        }
      ]
    },
    {
      "name": "1 - Auth",
      "item": [
        {
          "name": "Register User (optional)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newadmin\",\n  \"password\": \"newadmin123\",\n  \"role_name\": \"SuperAdmin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login SuperAdmin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"superadmin\",\n  \"password\": \"superadmin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2 - Roles & Permissions",
      "item": [
        {
          "name": "List Roles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/roles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "roles"]
            }
          }
        },
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Auditeur\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/roles",
              "host": ["{{baseUrl}}"],
              "path": ["api", "roles"]
            }
          }
        },
        {
          "name": "Assign Permissions to Role",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"permission_names\": [\n    \"Voir employés\",\n    \"Exporter rapports\"\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/roles/{{roleId}}/permissions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "roles", "{{roleId}}", "permissions"]
            }
          }
        }
      ]
    },
    {
      "name": "3 - Departments",
      "item": [
        {
          "name": "Create Department",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Operations\",\n  \"budget\": 90000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/departments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "departments"]
            }
          }
        },
        {
          "name": "List Departments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/departments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "departments"]
            }
          }
        },
        {
          "name": "Assign Manager",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/departments/{{departmentId}}/manager/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "departments", "{{departmentId}}", "manager", "{{employeeId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "4 - Employees",
      "item": [
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Patrick\",\n  \"last_name\": \"Ngoma\",\n  \"photo_url\": null,\n  \"email\": \"patrick.ngoma@entreprise.com\",\n  \"phone\": \"+243900001111\",\n  \"address\": \"Kinshasa\",\n  \"hire_date\": \"2026-02-20\",\n  \"status\": \"Actif\",\n  \"department_id\": 1,\n  \"role_id\": 4\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"]
            }
          }
        },
        {
          "name": "List Employees",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"]
            }
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+243999999999\",\n  \"address\": \"Kinshasa, Gombe\",\n  \"status\": \"Actif\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "{{employeeId}}"]
            }
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "{{employeeId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "5 - Payrolls",
      "item": [
        {
          "name": "Create Payroll",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_id\": 1,\n  \"base_salary\": 2000,\n  \"bonus\": 150,\n  \"overtime_hours\": 40,\n  \"deductions\": 30,\n  \"taxes\": 180\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payrolls",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payrolls"]
            }
          }
        },
        {
          "name": "List Payrolls",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/payrolls",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payrolls"]
            }
          }
        },
        {
          "name": "Export Payslip PDF",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/payrolls/{{payrollId}}/payslip",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payrolls", "{{payrollId}}", "payslip"]
            }
          }
        }
      ]
    },
    {
      "name": "6 - Attendance",
      "item": [
        {
          "name": "Check-in",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_id\": 1,\n  \"check_in\": \"2026-02-24T08:15:00\",\n  \"late_minutes\": 15\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/attendances/checkin",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendances", "checkin"]
            }
          }
        },
        {
          "name": "Check-out",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"attendance_id\": {{attendanceId}},\n  \"check_out\": \"2026-02-24T17:20:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/attendances/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendances", "checkout"]
            }
          }
        },
        {
          "name": "List Attendances",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/attendances",
              "host": ["{{baseUrl}}"],
              "path": ["api", "attendances"]
            }
          }
        }
      ]
    },
    {
      "name": "7 - Leaves",
      "item": [
        {
          "name": "Create Leave Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_id\": 1,\n  \"start_date\": \"2026-03-10\",\n  \"end_date\": \"2026-03-15\",\n  \"reason\": \"Congé familial\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/leaves",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leaves"]
            }
          }
        },
        {
          "name": "Approve Leave",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"Approuvé\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/leaves/{{leaveId}}/approval",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leaves", "{{leaveId}}", "approval"]
            }
          }
        },
        {
          "name": "List Leaves",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/leaves",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leaves"]
            }
          }
        }
      ]
    },
    {
      "name": "8 - Contracts",
      "item": [
        {
          "name": "Create Contract",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_id\": 1,\n  \"contract_type\": \"CDI\",\n  \"start_date\": \"2026-01-01\",\n  \"end_date\": null,\n  \"contractual_salary\": 2000,\n  \"document_path\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/contracts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "contracts"]
            }
          }
        },
        {
          "name": "List Contracts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/contracts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "contracts"]
            }
          }
        }
      ]
    },
    {
      "name": "9 - Reporting",
      "item": [
        {
          "name": "Global Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/reports/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reports", "stats"]
            }
          }
        }
      ]
    }
  ]
}
